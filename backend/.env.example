# ============================================================
# Explore Vieques — backend environment
# Copy to .env for local dev. On Railway/Render, set these as
# service variables instead (never commit real secrets).
# This file doubles as the checklist of vars the deploy needs.
# ============================================================

# --- Server ---
# PORT is injected automatically by Railway/Render — leave it unset there.
# Locally the server falls back to 3001.
PORT=3001
# MUST be "production" on the deploy host. It turns OFF the dev-only
# "allow any localhost origin" CORS rule in server.js.
NODE_ENV=development

# --- Database ---
# Supabase pooler connection string. Supabase dashboard ->
# Project Settings -> Database -> Connection string -> "Transaction pooler"
# (port 6543). If DATABASE_URL is set it wins over the DB_* fallback below.
# The ?search_path is handled in code (pool options), no need to add it here.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# LOCAL-ONLY fallback, used only when DATABASE_URL is unset:
DB_NAME=vieques_ai
DB_USER=vieques_app
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# --- Supabase (used to verify the user's JWT on protected routes) ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# --- Stripe (secret key stays server-side; never in the browser) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...           # from the Stripe webhook you register

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Frontend origins (used for CORS allowlist + Stripe redirect URLs) ---
LANDING_URL=http://localhost:5174         # https://explorevieques.org in prod
APP_URL=http://localhost:5173             # https://app.explorevieques.org in prod
